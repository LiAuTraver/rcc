{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "cppvsdbg",
      "request": "launch",
      "name": "ms-cpp debug rcc",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcc.exe",
      "preLaunchTask": "rust: cargo build",
      "args": [],
      "environment": [
        {
          "name": "RUST_BACKTRACE",
          "value": "short"
        },
        {
          "name": "RUSTC_TOOLCHAIN",
          "value": "Z:\\.packages\\.rustup\\toolchains\\nightly-x86_64-pc-windows-msvc"
        },
        {
          "name": "PYTHONIOENCODING",
          "value": "utf-8"
        }
      ],
      "console": "internalConsole"
    },
    {
      "type": "cppvsdbg",
      "request": "launch",
      "name": "ms-cpp debug rcc analyze",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcc.exe",
      "preLaunchTask": "rust: cargo build",
      "args": [
        "analyze",
        "${file}"
      ],
      "environment": [
        {
          "name": "RUST_BACKTRACE",
          "value": "short"
        },
        {
          "name": "RUSTC_TOOLCHAIN",
          "value": "Z:\\.packages\\.rustup\\toolchains\\nightly-x86_64-pc-windows-msvc"
        }
      ],
      "console": "internalConsole"
    },
    {
      "type": "lldb",
      "request": "launch",
      // codelldb provide better support as for breakpoint
      "name": "codelldb debug rcc",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcc.exe",
      "preLaunchTask": "rust: cargo build",
      "env": {
        "RUST_BACKTRACE": "short",
        "RUSTC_TOOLCHAIN": "Z:\\.packages\\.rustup\\toolchains\\nightly-x86_64-pc-windows-msvc"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "stopOnEntry": false,
      "sourceLanguages": [
        "rust",
        "C++",
        "C"
      ],
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "codelldb debug rcc with files",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcc.exe",
      "preLaunchTask": "rust: cargo build",
      "args": [
        "analyze",
        "${file}"
      ],
      "env": {
        "RUST_BACKTRACE": "short",
        "RUSTC_TOOLCHAIN": "Z:\\.packages\\.rustup\\toolchains\\nightly-x86_64-pc-windows-msvc"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "stopOnEntry": false,
      "sourceLanguages": [
        "rust",
        "C++",
        "C"
      ]
    },
    {
      "name": "rcc analyze",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/target/debug/rcc.exe",
      "args": [
        "analyze",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "outputCapture": "std",
      "env": {
        "RCC_OUTPUT_COLOR_OPTION": "ALWAYS"
      }
    },
    // // lldb-dap.exe not working
